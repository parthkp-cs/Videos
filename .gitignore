# OS
.DS_Store
*.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.env

# Manim render cache — large, regenerable
media/
scenes/media/
*/scenes/media/
Scripts/*/media/
Output/*/videos/

# Video renders — block Manim cache and scratch renders
*.mp4
*.mov
*.avi

# Allow approved scene renders and full episode cuts
!Output/*/renders/*.mp4
!Output/*/renders/*.mov
!Output/*/video/*.mp4
!Output/*/video/*.mov

# Old full-episode video folder — intentionally empty, videos tracked directly

# Scene render cache from old pipeline
Scripts/Iceland/scene_cache/

# Sensitive / auth — specific files only, not all JSON
token.json
*service_account*.json
*credentials*.json
client_secret*.json
